# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# Comma-separated allowed frontend origins
CORS_ORIGIN=https://olly-supermarket.vercel.app

# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# service_role key (NOT anon key) — Supabase Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-64-char-random-hex-string
JWT_EXPIRES_IN=7d

# ─── Email / Nodemailer ──────────────────────────────────────────────────────
# Gmail: enable 2FA → create App Password at myaccount.google.com/apppasswords
# Leave blank to disable email (app still works fully)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-16-char-app-password
EMAIL_FROM=OLLY Supermarket <noreply@olly.com>

# ─── OpenAI (optional — falls back to mock responses if blank) ───────────────
OPENAI_API_KEY=sk-...

# ─── Frontend URL (used inside email links) ──────────────────────────────────
FRONTEND_URL=https://olly-supermarket.vercel.app
