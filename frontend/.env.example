# ─── Supabase (public — used in browser) ─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# ─── SEO ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://olly-supermarket.vercel.app

# ─── Server-only (NOT prefixed with NEXT_PUBLIC_) ─────────────────────────────
# These are only used in API route handlers (server-side). Never exposed to the browser.

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# Strong random secret for signing JWTs
JWT_SECRET=generate-with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_EXPIRES_IN=7d

# ─── Email (Nodemailer / Gmail SMTP) ──────────────────────────────────────────
# Leave blank to disable email (app still works without it)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=OLLY Supermarket <noreply@olly.com>

# ─── OpenAI (optional — mock responses used if blank) ─────────────────────────
OPENAI_API_KEY=

# ─── Frontend URL (used in email links) ───────────────────────────────────────
FRONTEND_URL=https://olly-supermarket.vercel.app
